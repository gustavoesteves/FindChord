{
  "name": "find-chord",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.cjs",
    "build": "tsc -b && vite build",
    "test:curated": "vitest run --config vitest.curated.config.ts",
    "report:real-music": "jiti scripts/generate-real-music-audit-report.ts",
    "report:small-catalog": "jiti scripts/generate-small-catalog-research-report.ts",
    "import:split-catalog": "jiti scripts/split-musicxml-catalog.ts",
    "import:audit-split": "jiti scripts/audit-import-split-catalog.ts",
    "import:promote-candidates": "jiti scripts/promote-import-candidates.ts",
    "import:audit-promoted": "jiti scripts/audit-promoted-import-corpus.ts",
    "import:select-calibration": "jiti scripts/select-promoted-import-calibration-set.ts",
    "import:calibration-workplan": "jiti scripts/generate-calibration-workplan.ts",
    "import:audit-calibration-foundation": "jiti scripts/audit-calibration-foundation.ts",
    "import:audit-ranking-calibration": "jiti scripts/audit-ranking-calibration.ts",
    "import:audit-chromatic-calibration": "jiti scripts/audit-chromatic-calibration.ts",
    "import:audit-bass-calibration": "jiti scripts/audit-bass-calibration.ts",
    "import:audit-almada-example": "jiti scripts/audit-almada-example.ts",
    "import:audit-dominant-tension": "jiti scripts/audit-dominant-tension-corpus.ts",
    "import:audit-unresolved-dominants": "jiti scripts/audit-unresolved-dominant-tension.ts",
    "report:proposal-curation": "JITI_FS_CACHE=false JITI_MODULE_CACHE=false node --import jiti/register scripts/generate-proposal-curation-report.ts",
    "report:proposal-consequences": "JITI_FS_CACHE=false JITI_MODULE_CACHE=false node --import jiti/register scripts/generate-proposal-consequence-report.ts",
    "report:local-route-repetition": "JITI_FS_CACHE=false JITI_MODULE_CACHE=false node --import jiti/register scripts/generate-local-route-repetition-report.ts",
    "report:harmonization-density": "JITI_FS_CACHE=false JITI_MODULE_CACHE=false node --import jiti/register scripts/generate-harmonization-density-report.ts",
    "report:contextual-materials": "JITI_FS_CACHE=false JITI_MODULE_CACHE=false node --import jiti/register scripts/generate-contextual-material-audit.ts",
    "report:contextual-scales": "npm run report:contextual-materials",
    "report:melodic-materials": "JITI_FS_CACHE=false JITI_MODULE_CACHE=false node --import jiti/register scripts/generate-melodic-materials-audit.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tonal": "^6.4.3",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
